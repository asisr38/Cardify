# ─────────────────────────────────────────────────────────────────
# CardVault env template. Copy to .env and fill in.
#
# vite.config.ts accepts any of these client-key names (first match wins):
#   VITE_SUPABASE_URL → SUPABASE_URL
#   VITE_SUPABASE_ANON_KEY → NEXT_PUBLIC_SUPABASE_ANON_KEY → SUPABASE_ANON_KEY
# so the Vercel → Supabase integration's defaults work as-is.
# ─────────────────────────────────────────────────────────────────

# ── Shared (client + server) ────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Magic-link redirect. Leave blank to use window.location.origin.
VITE_SITE_URL=http://localhost:5173

# ── Server-only (Vercel serverless /api/*). NEVER expose to browser. ──

# Supabase service role — Settings → API → service_role.
# Bypasses RLS; used by /api/* to read private uploads and rate-limit counters.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional paid-tier scan pipeline. Leave unset to use free client-side
# fallbacks (Tesseract.js, regex, Web Speech API).
# GOOGLE_VISION_API_KEY=
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Daily per-user caps on paid endpoints.
OCR_DAILY_LIMIT=100
STRUCTURE_DAILY_LIMIT=100
TRANSCRIBE_DAILY_LIMIT=50
