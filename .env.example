# Supabase — from Project Settings → API
# VITE_ prefix makes these available in the browser. Do NOT place secrets here.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Site URL used as the magic-link redirect target. Must match the URL
# configured in Supabase → Auth → URL Configuration.
VITE_SITE_URL=http://localhost:5173
