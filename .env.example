# ─────────────────────────────────────────────────────────────────
# Client-side (browser) — VITE_ prefix required. NEVER put secrets here.
# ─────────────────────────────────────────────────────────────────

# Supabase — Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Magic-link redirect target. Must match Supabase → Auth → URL Configuration.
VITE_SITE_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────────
# Server-side (Vercel serverless /api/*) — NO VITE_ prefix.
# These stay on the server. Paste into Vercel → Project → Settings → Env.
# ─────────────────────────────────────────────────────────────────

# Supabase service role — Project Settings → API → service_role key.
# Bypasses RLS. Used to read uploaded scans and write rate-limit counters.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Cloud Vision — GCP Console → APIs & Services → Credentials →
# Create API Key. Restrict to Cloud Vision API.
GOOGLE_VISION_API_KEY=your-vision-api-key

# Anthropic — console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — platform.openai.com → API Keys. Used for Whisper transcription.
OPENAI_API_KEY=sk-...

# Daily per-user limits for the paid external APIs.
# Safe defaults; tune once you see usage.
OCR_DAILY_LIMIT=100
STRUCTURE_DAILY_LIMIT=100
TRANSCRIBE_DAILY_LIMIT=50
